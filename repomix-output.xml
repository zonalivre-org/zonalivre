    void Update()
    {
        TipCheck();

        if (canGenerate && firstActionTriggered == true)
        {
            if (actualTime < nextTime)
            {
                actualTime = Time.time;
            }
            else 
            {
                SpawnMango();
                nextTime = Time.time + cooldownBetweenMangos;
            }
        }
    }

    public override void StartMiniGame()
    {
        gameObject.SetActive(true);

        OnStart();

        UpdateScore();

        canGenerate = true;
